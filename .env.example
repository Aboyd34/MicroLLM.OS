# MicroLLM.OS — Environment Config
# Copy this file to .env and fill in your values

# ── Gemini API (free tier — 1,500 requests/day) ─────────────────────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Local model (optional overrides) ────────────────────────────────────────
# Uncomment to use a custom model path
# LLM_MODEL_PATH=./llm/models/my-custom-model.gguf

# ── REST bridge port (default 4000) ─────────────────────────────────────────
# LLM_PORT=4000
