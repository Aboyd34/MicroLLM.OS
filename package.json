{
  "name": "microllm-os",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "download-model": "node llm/download-model.cjs",
    "server": "node llm/server.cjs",
    "gemini": "node -r dotenv/config llm/gemini-cli.cjs",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder build --windows"
  },
  "build": {
    "appId": "com.microllm.app",
    "productName": "MicroLLM-4GB",
    "directories": { "output": "release" },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "llm/**/*",
      "package.json"
    ],
    "win": { "target": "nsis", "icon": "public/icon.ico" },
    "extraResources": [
      { "from": "llm/models", "to": "models", "filter": ["**/*.gguf"] }
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-llama-cpp": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
